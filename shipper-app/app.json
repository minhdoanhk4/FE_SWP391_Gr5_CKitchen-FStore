{
  "expo": {
    "name": "CKitchen Shipper",
    "slug": "ckitchen-shipper",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Cần quyền camera để quét mã QR đơn hàng"
      }
    },
    "android": {
      "package": "com.ckitchen.shipper",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Cần quyền camera để quét mã QR đơn hàng"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "14d6446f-bac8-470d-9af0-18e5ce20f541"
      }
    }
  }
}
