// ============================================================
// CKitchen FStore — Database Schema (DBML)
// BỔ SUNG: Dynamic Permission + Refresh Token
// ============================================================

// ---- CORE ----

Table stores {
  id varchar(10) [pk, note: 'CH001, CH002 ...']
  name nvarchar(100) [not null]
  address nvarchar(255) [not null]
  phone varchar(20)
  manager nvarchar(100)
  status varchar(20) [not null, note: 'active | maintenance | closed']
  open_date date
  created_at datetime [default: `now()`]
  updated_at datetime
}

Table kitchens {
  id varchar(10) [pk, note: 'BT001, BT002 ...']
  name nvarchar(100) [not null]
  address nvarchar(255) [not null]
  phone varchar(20)
  capacity int
  status varchar(20) [not null, note: 'active | inactive']
  created_at datetime [default: `now()`]
  updated_at datetime
}

// ---- USERS ----

Table users {
  id varchar(10) [pk, note: 'u1, u2 ...']
  name nvarchar(100) [not null]
  email varchar(100) [not null, unique]
  role varchar(30) [not null, note: 'LEGACY: store_staff | kitchen_staff | supply_coordinator | manager | admin']
  store_id varchar(10) [ref: > stores.id, note: 'NULL nếu không phải NV cửa hàng']
  status varchar(20) [not null, note: 'active | inactive']
  last_login datetime
  created_at datetime [default: `now()`]
  updated_at datetime
}

// ---- DYNAMIC PERMISSION (NEW) ----

Table roles {
  id varchar(20) [pk, note: 'ROLE_ADMIN, ROLE_MANAGER ...']
  name nvarchar(100) [not null, unique]
  code varchar(50) [not null, unique, note: 'admin | manager | store_staff ...']
  description nvarchar(255)
  is_system boolean [not null, default: true, note: 'Role hệ thống hay custom']
  status varchar(20) [not null, default: 'active', note: 'active | inactive']
  created_at datetime [default: `now()`]
  updated_at datetime
}

Table permissions {
  id varchar(30) [pk, note: 'PERM_ORDER_VIEW ...']
  code varchar(100) [not null, unique, note: 'orders:view, orders:create, users:assign_role ...']
  name nvarchar(150) [not null]
  module varchar(50) [not null, note: 'auth | orders | production | delivery | issues | products | users | config | stores']
  action varchar(30) [not null, note: 'view | create | update | delete | approve | assign']
  description nvarchar(255)
  status varchar(20) [not null, default: 'active', note: 'active | inactive']
  created_at datetime [default: `now()`]
  updated_at datetime
}

Table role_permissions {
  id int [pk, increment]
  role_id varchar(20) [not null, ref: > roles.id]
  permission_id varchar(30) [not null, ref: > permissions.id]
  created_at datetime [default: `now()`]

  indexes {
    (role_id, permission_id) [unique]
  }
}

Table user_roles {
  id int [pk, increment]
  user_id varchar(10) [not null, ref: > users.id]
  role_id varchar(20) [not null, ref: > roles.id]
  scope_type varchar(20) [not null, default: 'global', note: 'global | store | kitchen']
  scope_id varchar(10) [note: 'ID của store/kitchen theo scope_type, NULL nếu global']
  assigned_by varchar(10) [ref: > users.id, note: 'Người gán role']
  assigned_at datetime [not null, default: `now()`]
  expires_at datetime
  status varchar(20) [not null, default: 'active', note: 'active | revoked | expired']
  created_at datetime [default: `now()`]
  updated_at datetime

  indexes {
    (user_id, role_id, scope_type, scope_id) [unique]
  }
}

Table user_permissions {
  id int [pk, increment]
  user_id varchar(10) [not null, ref: > users.id]
  permission_id varchar(30) [not null, ref: > permissions.id]
  effect varchar(10) [not null, default: 'allow', note: 'allow | deny']
  scope_type varchar(20) [not null, default: 'global', note: 'global | store | kitchen']
  scope_id varchar(10) [note: 'ID của store/kitchen theo scope_type, NULL nếu global']
  reason nvarchar(255)
  assigned_by varchar(10) [ref: > users.id]
  assigned_at datetime [not null, default: `now()`]
  expires_at datetime
  created_at datetime [default: `now()`]
  updated_at datetime

  indexes {
    (user_id, permission_id, scope_type, scope_id) [unique]
  }
}

// ---- AUTH / TOKENS (NEW) ----

Table refresh_tokens {
  id varchar(50) [pk, note: 'RT001 ... hoặc UUID']
  user_id varchar(10) [not null, ref: > users.id]
  token_hash varchar(255) [not null, unique, note: 'Lưu hash thay vì token raw']
  jti varchar(100) [unique, note: 'JWT ID nếu dùng JWT refresh token']
  device_id varchar(100)
  device_name nvarchar(150)
  ip_address varchar(45)
  user_agent nvarchar(255)
  issued_at datetime [not null, default: `now()`]
  expires_at datetime [not null]
  revoked_at datetime
  revoked_reason nvarchar(255)
  replaced_by_token_id varchar(50) [ref: > refresh_tokens.id]
  is_revoked boolean [not null, default: false]
  created_at datetime [default: `now()`]
  updated_at datetime

  indexes {
    (user_id, is_revoked, expires_at)
  }
}

// ---- PRODUCTS & INGREDIENTS ----

Table products {
  id varchar(10) [pk, note: 'SP001 ...']
  name nvarchar(100) [not null]
  category nvarchar(50) [not null, note: 'Phở | Bún | Cơm | Bánh mì | Khai vị | Gia vị | Bán thành phẩm']
  unit nvarchar(20) [not null, note: 'phần | ổ | lít']
  price decimal(12,2) [not null, note: 'Giá bán (VND)']
  cost decimal(12,2) [not null, note: 'Giá vốn (VND)']
  image varchar(255)
  created_at datetime [default: `now()`]
  updated_at datetime
}

Table ingredients {
  id varchar(10) [pk, note: 'NL001 ...']
  name nvarchar(100) [not null]
  unit nvarchar(20) [not null, note: 'kg | lít']
  price decimal(12,2) [not null, note: 'Đơn giá (VND)']
  supplier nvarchar(100)
  min_stock int [not null, default: 0]
  created_at datetime [default: `now()`]
  updated_at datetime
}

Table recipes {
  id int [pk, increment]
  product_id varchar(10) [not null, ref: > products.id]
  ingredient_id varchar(10) [not null, ref: > ingredients.id]
  quantity decimal(10,4) [not null, note: 'Lượng NL cho 1 đơn vị SP']
  unit nvarchar(20) [not null]
  created_at datetime [default: `now()`]

  indexes {
    (product_id, ingredient_id) [unique]
  }
}

// ---- ORDERS ----

Table orders {
  id varchar(10) [pk, note: 'DH001 ...']
  store_id varchar(10) [not null, ref: > stores.id]
  kitchen_id varchar(10) [not null, ref: > kitchens.id]
  status varchar(20) [not null, default: 'pending', note: 'pending → confirmed → producing → ready → shipping → delivered | cancelled']
  priority varchar(10) [not null, default: 'normal', note: 'low | normal | high']
  created_at datetime [not null, default: `now()`]
  requested_date date [not null]
  notes nvarchar(500)
  created_by nvarchar(100)
  total decimal(15,2) [note: 'Tổng giá trị (VND)']
  updated_at datetime
}

Table order_items {
  id int [pk, increment]
  order_id varchar(10) [not null, ref: > orders.id]
  product_id varchar(10) [not null, ref: > products.id]
  quantity int [not null]
  unit nvarchar(20) [not null]
  created_at datetime [default: `now()`]
}

// ---- DELIVERIES ----

Table deliveries {
  id varchar(10) [pk, note: 'GH001 ...']
  order_id varchar(10) [not null, ref: > orders.id]
  coordinator_id varchar(10) [not null, ref: > users.id, note: 'Điều phối viên phụ trách giao hàng']
  status varchar(20) [not null, default: 'assigned', note: 'assigned → in_transit → delivered | failed']
  assigned_at datetime [not null, default: `now()`]
  delivered_at datetime [note: 'Thời điểm giao xong']
  notes nvarchar(500)
  receiver_name nvarchar(100) [note: 'Người nhận tại cửa hàng']
  temperature_ok boolean [default: true, note: 'Nhiệt độ đạt chuẩn?']
  created_at datetime [default: `now()`]
  updated_at datetime
}

// ---- INVENTORY ----

Table store_inventory {
  id int [pk, increment]
  store_id varchar(10) [not null, ref: > stores.id]
  product_id varchar(10) [not null, ref: > products.id]
  quantity int [not null, default: 0]
  unit nvarchar(20) [not null]
  min_stock int [not null, default: 0]
  expiry_date date
  updated_at datetime

  indexes {
    (store_id, product_id) [unique]
  }
}

Table kitchen_inventory {
  id int [pk, increment]
  ingredient_id varchar(10) [not null, ref: > ingredients.id]
  quantity decimal(10,2) [not null, default: 0]
  unit nvarchar(20) [not null]
  min_stock int [not null, default: 0]
  batch_no varchar(30) [note: 'LO-240412-01']
  expiry_date date
  supplier nvarchar(100)
  updated_at datetime
}

// ---- SALES ----

Table sales_records {
  id varchar(10) [pk, note: 'SR001 ...']
  store_id varchar(10) [not null, ref: > stores.id]
  date date [not null]
  total_revenue decimal(15,2) [not null]
  recorded_by nvarchar(100) [not null]
  recorded_at datetime [not null, default: `now()`]
  created_at datetime [default: `now()`]
}

Table sale_items {
  id int [pk, increment]
  sale_id varchar(10) [not null, ref: > sales_records.id]
  product_id varchar(10) [not null, ref: > products.id]
  quantity int [not null]
  unit nvarchar(20) [not null]
  unit_price decimal(12,2) [not null]
  created_at datetime [default: `now()`]
}

// ---- INVENTORY DISPOSALS ----

Table inventory_disposals {
  id int [pk, increment]
  inventory_type varchar(20) [not null, note: 'kitchen | store']
  item_id int [not null, note: 'FK to kitchen_inventory.id or store_inventory.id']
  item_name nvarchar(100) [not null]
  quantity_disposed decimal(10,2) [not null]
  unit nvarchar(20) [not null]
  reason nvarchar(200) [not null, note: 'expired | damaged | quality_issue']
  disposed_by varchar(10) [not null, ref: > users.id]
  disposed_at datetime [not null, default: `now()`]
}

// ---- PRODUCTION ----

Table production_plans {
  id varchar(10) [pk, note: 'KH-001 ...']
  product_id varchar(10) [not null, ref: > products.id]
  quantity int [not null]
  unit nvarchar(20) [not null]
  status varchar(20) [not null, default: 'planned', note: 'planned | in_progress | completed']
  start_date datetime [not null]
  end_date datetime
  staff nvarchar(100)
  notes nvarchar(500)
  created_at datetime [default: `now()`]
  updated_at datetime
}

Table plan_ingredients {
  id int [pk, increment]
  plan_id varchar(10) [not null, ref: > production_plans.id]
  ingredient_id varchar(10) [not null, ref: > ingredients.id, note: 'FK nguyên liệu']
  quantity decimal(10,4) [not null, note: 'Lượng cần dùng (số)']
  unit nvarchar(20) [not null]
  name nvarchar(100) [not null, note: 'Tên NL (denormalized cho hiển thị)']
  qty varchar(20) [not null, note: 'Lượng NL (denormalized, VD: 30kg)']
  created_at datetime [default: `now()`]
}

Table batches {
  id varchar(20) [pk, note: 'LO-SX-001 ...']
  order_id varchar(10) [ref: > orders.id, note: 'Đơn hàng tạo lô này (auto khi xác nhận đơn)']
  order_item_index int [note: 'Vị trí sản phẩm trong đơn hàng']
  plan_id varchar(10) [ref: > production_plans.id, note: 'Kế hoạch SX tạo ra lô này (legacy)']
  product_id varchar(10) [not null, ref: > products.id]
  kitchen_id varchar(10) [ref: > kitchens.id, note: 'Bếp sản xuất lô này']
  quantity int [not null]
  unit nvarchar(20) [not null]
  status varchar(20) [not null, default: 'confirmed', note: 'confirmed | in_progress | completed | planned']
  start_date datetime [note: 'Set khi bắt đầu SX']
  end_date datetime
  staff nvarchar(100)
  created_at datetime [default: `now()`]
  updated_at datetime
}

// ---- ISSUES ----

Table issues {
  id varchar(10) [pk, note: 'IS001 ...']
  order_id varchar(10) [ref: > orders.id, note: 'Optional - có thể NULL']
  delivery_id varchar(10) [ref: > deliveries.id, note: 'Optional - liên kết giao hàng']
  type varchar(30) [not null, note: 'late_delivery | shortage | quality | damaged']
  title nvarchar(200) [not null]
  description nvarchar(1000)
  status varchar(20) [not null, default: 'open', note: 'open | in_progress | resolved']
  priority varchar(10) [not null, default: 'medium', note: 'low | medium | high']
  created_at datetime [not null, default: `now()`]
  assignee nvarchar(100)
  updated_at datetime
}

// ---- AUDIT LOGS ----

Table audit_logs {
  id varchar(10) [pk, note: 'AL001 ...']
  action varchar(50) [not null, note: 'user_login | order_created | delivery_assigned | ...']
  user_id varchar(10) [not null, ref: > users.id]
  user_name nvarchar(100) [not null]
  details nvarchar(500)
  timestamp datetime [not null, default: `now()`]
  module varchar(50) [not null, note: 'auth | orders | production | delivery | issues | products | users | config | stores']
}

// ============================================================
// TABLE GROUPS (visual grouping in dbdiagram.io)
// ============================================================

TableGroup core {
  stores
  kitchens
}

TableGroup user_management {
  users
  roles
  permissions
  role_permissions
  user_roles
  user_permissions
}

TableGroup auth_security {
  refresh_tokens
}

TableGroup catalog {
  products
  ingredients
  recipes
}

TableGroup order_management {
  orders
  order_items
}

TableGroup delivery {
  deliveries
}

TableGroup inventory {
  store_inventory
  kitchen_inventory
  inventory_disposals
}

TableGroup sales {
  sales_records
  sale_items
}

TableGroup production {
  production_plans
  plan_ingredients
  batches
}

TableGroup tracking {
  issues
  audit_logs
}